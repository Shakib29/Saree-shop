# ===========================================
# House of Jaee Backend — Environment Variables
# Copy this file to .env and fill in real values
# ===========================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=house_of_jaee

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Admin Seed Credentials (used only by seed/seed.js)
SEED_ADMIN_NAME=Jaee Deshmukh
SEED_ADMIN_EMAIL=admin@houseofjaee.com
SEED_ADMIN_PASSWORD=Admin@123

# CORS
FRONTEND_URL=http://localhost:5173
